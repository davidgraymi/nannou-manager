{
  "name": "nannou-manager-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.js --bundle --format=iife --outfile=dist/main.js && esbuild index.html style.css --loader:.html=copy --loader:.css=copy --outdir=dist",
    "watch": "esbuild index.html style.css --loader:.html=copy --loader:.css=copy --outdir=dist && esbuild src/main.js --bundle --format=iife --outfile=dist/main.js --watch"
  },
  "dependencies": {
    "lucide": "next"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
