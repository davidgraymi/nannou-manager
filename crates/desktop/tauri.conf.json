{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nannou Manager",
  "identifier": "com.nannou-manager",
  "build": {
    "frontendDist": "./dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Nannou Manager",
        "width": 960,
        "height": 620,
        "minWidth": 640,
        "minHeight": 400,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
