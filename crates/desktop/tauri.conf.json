{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nannou Manager",
  "version": "0.1.0",
  "identifier": "com.nannou-manager",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Nannou Manager",
        "width": 960,
        "height": 620,
        "minWidth": 640,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
